# Meta Ads Intelligence — Environment Variables
# Copy this file to .env and fill in your credentials

# ─── Meta Marketing API Credentials ─────────────────────────────────────────
META_ACCESS_TOKEN=your_system_user_access_token_here
META_AD_ACCOUNT_ID=act_XXXXXXXXXXXXXXXXX
META_APP_ID=your_app_id_here
META_APP_SECRET=your_app_secret_here
META_API_VERSION=v19.0

# ─── Optional Settings ────────────────────────────────────────────────────────
# Override data output directory (default: data/raw)
# META_RAW_DATA_DIR=data/raw

# Override processed data directory (default: data/processed)
# META_PROCESSED_DIR=data/processed

# Debug mode (set to 1 to enable verbose logging)
# META_DEBUG=0
